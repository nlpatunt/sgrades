# Application Environment
ENVIRONMENT=development

# API Keys
OPENROUTER_API_KEY=your-openrouter-key-here

# Database Configuration
# DB_TYPE options: create-on-boot, local-postgres, local-mysql, global-postgres, global-mysql
DB_TYPE=local-postgres

# PostgreSQL Configuration (when using local-postgres or global-postgres)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sgrades

# SQLite Configuration (when using create-on-boot)
DB_PATH=./sgrades.db

# Docker-specific Configuration
APP_PORT=8000